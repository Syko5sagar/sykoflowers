<!DOCTYPE html>
<html lang="kn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Syko Live - WhatsApp Style</title>
    <script src="https://unpkg.com/peerjs@1.5.2/dist/peerjs.min.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.0.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.0.0/firebase-database-compat.js"></script>
    <style>
        body { background: #000; color: white; font-family: sans-serif; margin: 0; overflow: hidden; }
        .main-container { display: flex; flex-direction: column; height: 100vh; position: relative; }
        
        /* Video Windows */
        .video-section { flex: 1; display: flex; position: relative; background: #111; }
        .video-box { flex: 1; border: 1px solid #222; position: relative; }
        video { width: 100%; height: 100%; object-fit: cover; }
        
        /* Floating Mini Profile */
        .remote-info { position: absolute; top: 20px; left: 20px; z-index: 5; background: rgba(0,0,0,0.5); padding: 5px 15px; border-radius: 20px; border: 1px solid #00f2fe; }

        /* Floating Controls (WhatsApp Style) */
        .call-tools { position: absolute; bottom: 100px; width: 100%; display: flex; justify-content: center; gap: 20px; z-index: 10; }
        .tool-btn { background: rgba(255, 255, 255, 0.2); border: none; padding: 15px; border-radius: 50%; cursor: pointer; color: white; transition: 0.3s; width: 60px; height: 60px; font-size: 18px; }
        .tool-btn.active { background: #ff4444; }

        /* Bottom Control Bar */
        .bottom-bar { background: #111; padding: 15px; display: flex; align-items: center; gap: 10px; border-top: 2px solid #ff0055; }
        input { flex: 1; padding: 12px; border-radius: 25px; border: none; background: #222; color: white; }
        .btn-next { background: #ff0055; color: white; padding: 12px 25px; border-radius: 25px; font-weight: bold; border: none; cursor: pointer; }

        #status-msg { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 20; background: rgba(0,0,0,0.8); padding: 15px 30px; border-radius: 10px; color: #ffd700; display: none; }
    </style>
</head>
<body>

<div class="main-container">
    <div id="status-msg">Searching... 🔍</div>

    <div class="video-section">
        <div class="remote-info" id="remoteTag">Stranger</div>
        <div class="video-box">
            <video id="remoteVideo" autoplay playsinline></video>
        </div>
        <div class="video-box" style="max-width: 150px; height: 200px; position: absolute; bottom: 20px; right: 20px; border: 2px solid #00f2fe; border-radius: 10px; z-index: 15;">
            <video id="localVideo" autoplay muted playsinline></video>
        </div>
    </div>

    <div class="call-tools">
        <button class="tool-btn" id="muteBtn" onclick="toggleAudio()">🎤</button>
        <button class="tool-btn" id="videoBtn" onclick="toggleVideo()">🎥</button>
        <button class="tool-btn" onclick="flipCamera()">🔄</button>
    </div>

    <div class="bottom-bar">
        <button class="btn-next" onclick="findStranger()">NEXT ⏭️</button>
        <input type="text" id="chatInput" placeholder="Type message...">
        <button style="background:#00f2fe; border:none; padding:10px 20px; border-radius:20px; cursor:pointer;">SEND</button>
    </div>
</div>

<script>
    // 1. Firebase ಕನೆಕ್ಷನ್ (ನಿಮ್ಮ ಲಿಂಕ್ ಇಲ್ಲಿದೆ)
    const firebaseConfig = { databaseURL: "https://sykolive-846a3-default-rtdb.firebaseio.com/" };
    firebase.initializeApp(firebaseConfig);
    const db = firebase.database();
    const lobbyRef = db.ref("lobby");

    let peer = new Peer();
    let myStream;
    let currentCall;
    let isMuted = false;
    let isVideoOff = false;
    let currentFacingMode = "user"; // Front camera

    // 2. ಕ್ಯಾಮೆರಾ ಶುರುಮಾಡುವುದು
    async function startCamera(facingMode = "user") {
        if(myStream) myStream.getTracks().forEach(track => track.stop());
        try {
            myStream = await navigator.mediaDevices.getUserMedia({ 
                video: { facingMode: facingMode }, 
                audio: true 
            });
            document.getElementById('localVideo').srcObject = myStream;
        } catch (err) {
            alert("ಕ್ಯಾಮೆರಾ ಪರ್ಮಿಷನ್ ಅಗತ್ಯವಿದೆ!");
        }
    }
    startCamera();

    // 3. ರಾಂಡಮ್ ಆಗಿ ಕನೆಕ್ಟ್ ಮಾಡುವುದು (Real-time)
    function findStranger() {
        if(currentCall) currentCall.close();
        document.getElementById('remoteVideo').srcObject = null;
        const msg = document.getElementById('status-msg');
        msg.style.display = "block";
        msg.innerText = "Searching for someone... 🔍";

        lobbyRef.once("value", snapshot => {
            let found = false;
            snapshot.forEach(child => {
                if (!found && child.val() !== peer.id) {
                    found = true;
                    let strangerId = child.val();
                    connectToStranger(strangerId);
                    db.ref("lobby/" + child.key).remove();
                }
            });
            if (!found) {
                let myEntry = lobbyRef.push(peer.id);
                myEntry.onDisconnect().remove();
                msg.innerText = "Waiting for a partner... ⏳";
            }
        });
    }

    function connectToStranger(id) {
        const call = peer.call(id, myStream);
        setupCall(call);
    }

    peer.on('call', call => {
        call.answer(myStream);
        setupCall(call);
    });

    function setupCall(call) {
        currentCall = call;
        document.getElementById('status-msg').style.display = "none";
        call.on('stream', remoteStream => {
            document.getElementById('remoteVideo').srcObject = remoteStream;
        });
    }

    // 4. WhatsApp Style ಫೀಚರ್ಸ್‌ಗಳು
    function toggleAudio() {
        isMuted = !isMuted;
        myStream.getAudioTracks()[0].enabled = !isMuted;
        document.getElementById('muteBtn').classList.toggle('active', isMuted);
        document.getElementById('muteBtn').innerText = isMuted ? "🔇" : "🎤";
    }

    function toggleVideo() {
        isVideoOff = !isVideoOff;
        myStream.getVideoTracks()[0].enabled = !isVideoOff;
        document.getElementById('videoBtn').classList.toggle('active', isVideoOff);
        document.getElementById('videoBtn').innerText = isVideoOff ? "❌🎥" : "🎥";
    }

    function flipCamera() {
        currentFacingMode = currentFacingMode === "user" ? "environment" : "user";
        startCamera(currentFacingMode);
    }
</script>
</body>
</html>
